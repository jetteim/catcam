{
  "profile": "macos-dev",
  "camera": {
    "backend": "mac",
    "device": "default",
    "width": 1280,
    "height": 720,
    "fps": 15
  },
  "analysis": {
    "width": 640,
    "height": 360,
    "fps": 10,
    "confirm_frames": 2,
    "warmup_frames": 15,
    "motion_min_area": 750,
    "motion_min_score": 0.08
  },
  "recording": {
    "root": "records",
    "pre_event_seconds": 3.0,
    "post_event_seconds": 3.0,
    "merge_gap_seconds": 3.0,
    "container": "mp4"
  },
  "detection": {
    "backend": "opencv_yolox",
    "model_path": "models/opencv_yolox/object_detection_yolox_2022nov.onnx",
    "person_label": "person",
    "cat_label": "cat",
    "confidence_threshold": 0.35,
    "nms_threshold": 0.5
  },
  "baby_resolver": {
    "mode": "disabled",
    "roi": [0.2, 0.2, 0.8, 0.95]
  }
}
