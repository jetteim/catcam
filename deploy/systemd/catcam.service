[Unit]
Description=CatCam offline event capture
After=local-fs.target

[Service]
Type=simple
User=pi
WorkingDirectory=%h/catcam
Environment=PYTHONUNBUFFERED=1
ExecStart=%h/catcam/.venv/bin/python -m catcam.cli --config %h/catcam/configs/rpi4-prod.json run
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
